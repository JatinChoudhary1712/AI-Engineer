   "source": [
    "Recursion : Function calls itself until condition met"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "befe1871",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "3\n",
      "2\n",
      "1\n"
     ]
    }
   ],
   "source": [
    "def count(n):\n",
    "    if n == 0:\n",
    "        return\n",
    "    print(n)\n",
    "    count(n-1)\n",
    "\n",
    "count(3)\n",
    "# 3 2 1"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "a537a250",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "120\n"
     ]
    }
   ],
   "source": [
    "def fact(n):\n",
    "    if n == 1:\n",
    "        return 1\n",
    "    return n * fact(n-1)\n",
    "\n",
    "print(fact(5))   # 120"
   ]
  }
 ],
