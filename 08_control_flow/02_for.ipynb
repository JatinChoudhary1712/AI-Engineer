   ],
   "source": [
    "list = [1,2,3,4,5]\n",
    "\n",
    "for i in list:\n",
    "    print(i)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "dc2cf765",
   "metadata": {},
   "outputs": [],
   "source": [
    "dic = {\n",
    "    \"a\" : 1 , \"b\" : 2\n",
    "}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "11d5d794",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "key is a\n",
      "key is b\n"
     ]
    }
   ],
   "source": [
    "for k , v in dic.items():\n",
    "    print(f\"key is {k}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "e791bfcd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
