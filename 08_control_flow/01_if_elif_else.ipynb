   "source": [
    "* **if** → checks a condition (runs if True)\n",
    "* **elif** → checks another condition if previous ones were False\n",
    "* **else** → runs when all above conditions are False\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "f9d19299",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "next hi\n"
     ]
    }
   ],
   "source": [
    "a = 10 \n",
    "\n",
    "if a < 10 : \n",
    "    print(\"helo\")\n",
    "\n",
    "elif a == 10:\n",
    "    print(\"next hi\")\n",
    "\n",
    "else : \n",
    "    print(\"hi\")"
   ]
  },
